generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters", "jsonProtocol"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                 Int      @id @default(autoincrement())
  platform           String
  username           String
  totalMessages      Int
  unreadMessages     Int
  oldestUnreadMessage String
  lastUpdated        DateTime @default(now())

  @@unique([platform, username], name: "platform_username")
} 